# Template for .streamlit/secrets.toml (local) or the Streamlit Cloud
# "Secrets" panel (App -> Settings -> Secrets). Copy, fill in, never commit.

APP_PASSWORD = ""

# ── Google service account (GA4, Search Console, LinkedIn sheet) ─────────────
GA4_PROPERTY_ID         = ""
GA4_PROJECT_ID          = ""
GA4_PRIVATE_KEY_ID      = ""
GA4_PRIVATE_KEY         = ""
GA4_CLIENT_EMAIL        = ""
GA4_CLIENT_ID           = ""
GA4_CLIENT_X509_CERT_URL = ""
GSC_SITE_URL            = ""
LINKEDIN_SHEET_ID       = ""

# ── Gravity Forms (Leads page) ────────────────────────────────────────────────
GF_SITE_URL    = ""
GF_API_KEY     = ""
GF_PRIVATE_KEY = ""
GF_FORM_IDS    = ""

# ── Meta / Facebook Ads ───────────────────────────────────────────────────────
# System User token with ads_read, from Meta Business Manager
# (Business Settings -> Users -> System Users -> Generate Token).
META_ACCESS_TOKEN  = ""
# Format: act_XXXXXXXXXX
META_AD_ACCOUNT_ID = ""

# ── Google Ads ────────────────────────────────────────────────────────────────
# Developer token: Google Ads -> Tools & Settings -> API Center.
# Client ID/secret: Google Cloud Console "Desktop app" OAuth client
# with the Google Ads API enabled.
# Refresh token: run  python generate_refresh_token.py  locally.
GOOGLE_ADS_DEVELOPER_TOKEN = ""
GOOGLE_ADS_CLIENT_ID       = ""
GOOGLE_ADS_CLIENT_SECRET   = ""
GOOGLE_ADS_REFRESH_TOKEN   = ""
# Format: 123-456-7890 (dashes optional)
GOOGLE_ADS_CUSTOMER_ID     = ""
# Only needed if the account is accessed through a Manager (MCC) account:
# GOOGLE_ADS_LOGIN_CUSTOMER_ID = ""
